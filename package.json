{
  "name": "swa-website",
  "version": "1.0.0",
  "description": "SWA Website application with PostgreSQL backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "prod": "set NODE_ENV=production&& node server.js",
    "init": "node backend/scripts/init-app.js",
    "init:db": "node backend/scripts/init-db.js",
    "init:keys": "node backend/utils/keyGenerator.js --init",
    "migrate": "node -e \"require('./backend/migrations')\"",
    "migrate:payment": "node backend/migrations/run-payment-migrations.js",
    "migrate:payment:rollback": "node backend/migrations/run-payment-migrations.js rollback",
    "reset": "del .initialized && node server.js",
    "rotate:keys": "node backend/utils/keyGenerator.js --rotate",
    "keys:status": "node backend/utils/keyGenerator.js --status",
    "keys:schedule": "node backend/utils/keyGenerator.js --schedule"
  },
  "keywords": [
    "swa",
    "welfare",
    "association",
    "postgresql",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.8",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^24.40.0",
    "sequelize": "^6.35.2"
  }
}
