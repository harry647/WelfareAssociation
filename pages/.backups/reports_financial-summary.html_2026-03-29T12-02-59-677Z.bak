<!DOCTYPE html>
<html lang="en">

<head>
    <!-- W3 Schools HTML Includes -->
    <script src="https://www.w3schools.com/lib/w3.js"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Financial Summary - SWA financial overview">
    <meta name="keywords" content="SWA, financial, summary, report">
    <title>Financial Summary - Student Welfare Association | JOOUST</title>
    
    <!-- Main Styles -->
    <link rel="stylesheet" href="../../src/styles/main.css">
    <link rel="stylesheet" href="../../src/styles/original/header.css">
    <link rel="stylesheet" href="../../src/styles/pages/shared/navigation.css">
    <link rel="stylesheet" href="../../src/styles/original/footer.css">
    <!-- Report Styles -->
    <link rel="stylesheet" href="../../src/styles/pages/reports/financial-summary.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>

<body>
    <!-- Shared Header -->
  <div w3-include-html="../shared/header.html"></div>

    <!-- Page Header -->
    <header class="report-header">
        <h1><i class="fas fa-chart-line"></i> Financial Summary</h1>
        <p>Comprehensive financial overview and breakdown</p>
    </header>

    <main class="report-container">
        <!-- Summary Stats -->
        <section class="report-stats">
            <div class="stat-card">
                <i class="fas fa-money-bill-wave"></i>
                <h3>Total Income</h3>
                <p class="stat-number">-</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-credit-card"></i>
                <h3>Total Expenses</h3>
                <p class="stat-number">-</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-piggy-bank"></i>
                <h3>Net Balance</h3>
                <p class="stat-number">-</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-hand-holding-usd"></i>
                <h3>Loans Disbursed</h3>
                <p class="stat-number">-</p>
            </div>
        </section>

        <!-- Financial Breakdown -->
        <section class="report-table">
            <h2>Financial Breakdown</h2>
            <table>
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Percentage %</th>
                    </tr>
                </thead>
                <tbody id="financialTableBody">
                    <!-- Data loaded dynamically -->
                </tbody>
            </table>
        </section>
    </main>

    <!-- Shared Footer -->
  <div w3-include-html="../shared/footer.html"></div>

    <!-- W3 Schools HTML Includes Script -->
    <script>
        w3.includeHTML();
    </script>

    <script type="module" src="../../src/scripts/pages/reports/financial-summary.js"></script>