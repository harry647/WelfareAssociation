# ============================================
# SMS Configuration (for sending SMS messages)
# ============================================
# SMS_PROVIDER=simulation  # Options: twilio, africastalking, simulation
# Without provider config, SMS will be simulated
# Twilio SMS:
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+254712345678
# Africa's Talking SMS:
# SMS_PROVIDER=africastalking
# AFRICASTALKING_API_KEY=
# AFRICASTALKING_USERNAME=sandbox

# ============================================
# WhatsApp Configuration (for sending WhatsApp messages)
# ============================================
# WHATSAPP_PROVIDER=simulation  # Options: twilio, meta, infobip, simulation
# Without provider config, WhatsApp will be simulated
# Twilio WhatsApp:
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+254712345678
# Meta Cloud API (Facebook WhatsApp):
# WHATSAPP_PROVIDER=meta
# META_WHATSAPP_PHONE_ID=
# META_ACCESS_TOKEN=
# Infobip WhatsApp:
# WHATSAPP_PROVIDER=infobip
# INFOBIP_BASE_URL=
# INFOBIP_API_KEY=
# INFOBIP_WHATSAPP_NUMBER=+254712345678