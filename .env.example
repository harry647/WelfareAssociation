# PostgreSQL Connection
# Use POSTGRES_URI_DEV for local development
# Use POSTGRES_URI_PROD for production (Render, etc.)
POSTGRES_URI_DEV=postgresql://postgres:password@localhost:5432/swa_db
POSTGRES_URI_PROD=postgresql://username:password@host:5432/swa_db

# You can also use DATABASE_URL (Render sets this automatically)
# DATABASE_URL=postgresql://username:password@host:5432/swa_db

# Server Configuration
PORT=3000

# JWT Secret (generate a secure random string)
JWT_SECRET=your_jwt_secret_here

# Session Configuration
SESSION_SECRET=your_session_secret_here

# Email Configuration (optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# File Upload Settings
MAX_FILE_SIZE=10485760

# API Keys (add as needed)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+1234567890