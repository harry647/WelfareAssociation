# PostgreSQL Connection
# Use POSTGRES_URI_DEV for local development
# Use POSTGRES_URI_PROD for production (Render, etc.)
POSTGRES_URI_DEV=postgresql://postgres:password@localhost:5432/swa_db
POSTGRES_URI_PROD=postgresql://username:password@host:5432/swa_db

# You can also use DATABASE_URL (Render sets this automatically)
# DATABASE_URL=postgresql://username:password@host:5432/swa_db

# Server Configuration
PORT=3000

# JWT Secret (generate a secure random string)
JWT_SECRET=your_jwt_secret_here

# Session Configuration
SESSION_SECRET=your_session_secret_here

# Email Configuration (optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="SWA Admin" <noreply@swa.org>

# SMS Configuration (optional - for sending SMS)
# SMS_PROVIDER=simulation  # Options: twilio, africastalking, simulation
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+254712345678
# AFRICASTALKING_API_KEY=your_africastalking_api_key
# AFRICASTALKING_USERNAME=your_username

# WhatsApp Configuration (optional - for sending WhatsApp messages)
# WHATSAPP_PROVIDER=simulation  # Options: twilio, meta, infobip, simulation
# TWILIO_WHATSAPP_NUMBER=whatsapp:+254712345678  # For Twilio WhatsApp
# META_WHATSAPP_PHONE_ID=your_phone_number_id
# META_ACCESS_TOKEN=your_meta_access_token
# INFOBIP_BASE_URL=your_domain.api.infobip.com
# INFOBIP_API_KEY=your_infobip_api_key
# INFOBIP_WHATSAPP_NUMBER=+254712345678

# File Upload Settings
MAX_FILE_SIZE=10485760

# M-Pesa Configuration (for payments)
# Get these from Safaricom Daraja API
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here
MPESA_SHORTCODE=123456
MPESA_PAYBILL=123456
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
# Use 'sandbox' for testing, 'production' for live
MPESA_ENV=sandbox

# Stripe Configuration (optional - for card payments)
# STRIPE_PUBLIC_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOHOOK_SECRET=whsec_xxxxx

# Flutterwave Configuration (optional - for card payments)
# FLW_PUBLIC_KEY=your_flutterwave_public_key
# FLW_SECRET_KEY=your_flutterwave_secret_key
# FLW_SECRET_HASH=your_flutterwave_secret_hash

# Bank Configuration (for bank transfers)
BANK_NAME=Kenya Commercial Bank
BANK_ACCOUNT_NAME=SWA JOOUST
BANK_ACCOUNT_NUMBER=1234567890
BANK_BRANCH=Kenyatta Avenue Branch

# API Keys (add as needed)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+1234567890